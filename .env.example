# LLAMA_MODEL_PATH: Required for local LLaMA model inference.
# Example: models/llama-2-7b.gguf
LLAMA_MODEL_PATH="models/llama-2-7b.gguf"

# Optional model path overrides for larger or alternate LLaMA weights.
#LLAMA_MODEL_PATH_13B="models/llama-2-13b.gguf"
#LLAMA_MODEL_PATH_3B="models/llama-3-8b.gguf"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
